<h1>My Blog</h1>

<% if (!posts || posts.length === 0) { %>
  <p>No posts yet. <a href="/posts/new">Create the first one</a>.</p>
<% } else { %>
  <% posts.forEach((post) => { %>
    <article class="post">
      <h2><%= post.title %></h2>
      <p><%= post.content %></p>
      <small>Created: <%= new Date(post.createdAt).toLocaleString() %></small>
    </article>
  <% }) %>
<% } %>