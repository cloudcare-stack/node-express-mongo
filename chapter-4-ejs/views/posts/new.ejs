<h1>New Post</h1>

<form method="POST" action="/posts">
  <label>
    Title
    <input name="title" type="text" maxlength="120" required />
  </label>

  <label>
    Content
    <textarea name="content" rows="8" maxlength="5000" required></textarea>
  </label>

  <button type="submit">Create Post</button>
</form>