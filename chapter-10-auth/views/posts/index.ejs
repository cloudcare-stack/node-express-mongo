<h1>All Posts</h1>

<% if (currentUser) { %>
  <a class="btn btn-primary btn-sm" href="/posts/new">+ New Post</a>
<% } %>

<% if (!posts || posts.length === 0) { %>
  <p>No posts yet.</p>
<% } else { %>
  <% posts.forEach((p) => { %>
    <% const isOwner = currentUser && p.author && String(p.author._id) === String(currentUser.id); %>
    
    <article class="post">
      <h2><a href="/posts/<%= p._id %>"><%= p.title %></a></h2>
      <small><%= new Date(p.createdAt).toLocaleString() %></small>
      <p><%= (p.content || "").slice(0, 140) %><%= (p.content || "").length > 140 ? "..." : "" %></p>

      <p>
        <a href="/posts/<%= p._id %>">View</a>
        <% if (isOwner) { %>
          | <a href="/posts/<%= p._id %>/edit">Edit</a>
        <% } %>
      </p>
      <small>
        By <%= p.author?.username %>
      </small>
    </article>
  <% }) %>
<% } %>